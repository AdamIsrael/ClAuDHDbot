CLAUDHD_DISCORD__TOKEN=your_discord_bot_token
CLAUDHD_DISCORD__OWNER_ID=your_discord_user_id

# LLM provider: claude, ollama, or openai
CLAUDHD_LLM__PROVIDER=openai
CLAUDHD_LLM__API_KEY=your_api_key
# For OpenAI-compatible: base URL (e.g. http://localhost:1234/v1, https://api.openai.com/v1)
CLAUDHD_LLM__BASE_URL=http://localhost:1234/v1
CLAUDHD_LLM__MODEL=your_model_name

# Database (SQLite). The default below is relative to the working directory;
# use an absolute path to keep state in a fixed location across runs. The DB
# is created on first run and migrations are applied automatically.
# CLAUDHD_DATABASE__URL=sqlite:claudhdbot.db?mode=rwc
